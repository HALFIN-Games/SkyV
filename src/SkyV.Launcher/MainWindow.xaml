<Window x:Class="SkyV.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SkyV.Launcher"
        mc:Ignorable="d"
        Title="SkyV Launcher" Height="720" Width="1060"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="18"
                BorderBrush="{StaticResource SkyV.BorderBrush}"
                BorderThickness="1"
                Background="{StaticResource SkyV.SurfaceBrush}"
                Padding="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                    <TextBlock Text="Vokun Roleplay" FontSize="26" FontWeight="Bold" />
                    <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource SkyV.MutedBrush}" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SkyV.SecondaryButton}" Content="Rules" Margin="0,0,10,0" Click="OnOpenRulesClicked" />
                    <Button Style="{StaticResource SkyV.SecondaryButton}" Content="Settings" Click="OnOpenSettingsClicked" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,0"
                CornerRadius="18"
                BorderBrush="{StaticResource SkyV.BorderBrush}"
                BorderThickness="1"
                Background="{StaticResource SkyV.Surface2Brush}"
                Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding TitleText}"
                           FontSize="30"
                           FontWeight="Bold" />

                <TextBlock Grid.Row="1"
                           Text="{Binding BodyText}"
                           Foreground="{StaticResource SkyV.MutedBrush}"
                           FontSize="15"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap" />

                <Border Grid.Row="2"
                        Margin="0,18,0,0"
                        CornerRadius="14"
                        BorderBrush="{StaticResource SkyV.BorderBrush}"
                        BorderThickness="1"
                        Background="{StaticResource SkyV.SurfaceBrush}"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Detected Join Intent" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding IntentSummary}" Foreground="{StaticResource SkyV.MutedBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,18,0,0">
                    <Button Style="{StaticResource SkyV.PrimaryButton}" Content="{Binding PrimaryButtonText}" Width="200" IsEnabled="{Binding IsPrimaryEnabled}" Click="OnPrimaryActionClicked" />
                    <Button Style="{StaticResource SkyV.SecondaryButton}" Content="Launch game" Width="180" Margin="12,0,0,0" IsEnabled="{Binding IsLaunchEnabled}" Click="OnLaunchSkseClicked" />
                    <Button Style="{StaticResource SkyV.SecondaryButton}" Content="Copy diagnostics" Width="160" Margin="12,0,0,0" Click="OnCopyDiagnosticsClicked" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
