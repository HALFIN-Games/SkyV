<Window x:Class="SkyV.Launcher.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="460"
        Width="720"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Vokun WL Settings" FontSize="22" FontWeight="Bold" />
        <TextBlock Grid.Row="1" Text="These settings are stored locally for this Windows user." Foreground="{StaticResource SkyV.MutedBrush}" Margin="0,8,0,0" />

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Website URL" VerticalAlignment="Center" />
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WebsiteBaseUrl}" Margin="10,0,10,0" />
            <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource SkyV.SecondaryButton}" Content="Test" Click="OnTestWebsite" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Queue URL" VerticalAlignment="Center" Margin="0,10,0,0" />
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding QueueBaseUrl}" Margin="10,10,10,0" />
            <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource SkyV.SecondaryButton}" Content="Test" Margin="0,10,0,0" Click="OnTestQueue" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Pack URL" VerticalAlignment="Center" Margin="0,10,0,0" />
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PackUrl}" Margin="10,10,10,0" />
            <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource SkyV.SecondaryButton}" Content="Test" Margin="0,10,0,0" Click="OnTestPack" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Skyrim Path" VerticalAlignment="Center" Margin="0,10,0,0" />
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SkyrimInstallPath}" Margin="10,10,10,0" />
            <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource SkyV.SecondaryButton}" Content="Browse" Margin="0,10,0,0" Click="OnBrowseSkyrim" />
        </Grid>

        <Border Grid.Row="3"
                Margin="0,18,0,0"
                CornerRadius="14"
                BorderBrush="{StaticResource SkyV.BorderBrush}"
                BorderThickness="1"
                Background="{StaticResource SkyV.SurfaceBrush}"
                Padding="14">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource SkyV.MutedBrush}" TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource SkyV.SecondaryButton}" Content="Cancel" Width="120" Click="OnCancel" />
            <Button Style="{StaticResource SkyV.PrimaryButton}" Content="Save" Width="120" Margin="10,0,0,0" Click="OnSave" />
        </StackPanel>
    </Grid>
</Window>
